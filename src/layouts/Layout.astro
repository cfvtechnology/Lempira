---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  faq?: FAQItem[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = "/og-image.png",
  faq = [],
} = Astro.props;

const siteName = "Lempira";
const publisherName = "CFV Technology";
const locale = "es_HN";
---

<!doctype html>
<html lang="es-HN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={publisherName} />
    <meta name="keywords" content="calculadora de precios, precio de venta, margen de ganancia, calcular precio de un producto, IVA Honduras, precio mayorista, porcentaje de ganancia, emprendedores Honduras, como fijar precios, formula precio de venta, calculadora gratis, Lempiras HNL" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:secure_url" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Lempira · Calculadora gratuita de precios de venta para emprendedores hondureños" />
    <meta property="og:locale" content={locale} />
    <meta property="og:site_name" content={siteName} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    <meta name="twitter:image:alt" content="Lempira · Calculadora gratuita de precios de venta para emprendedores hondureños" />

    <!-- JSON-LD Structured Data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        name: "Lempira - Calculadora de precios de venta",
        alternateName: "Lempira",
        description,
        url: canonical,
        applicationCategory: "BusinessApplication",
        applicationSubCategory: "Calculadora de precios",
        operatingSystem: "All",
        browserRequirements: "Requires JavaScript and HTML5 support",
        featureList: "Calcular precio de venta de un producto, calcular margen de ganancia en porcentaje, incluir IVA e impuestos en el precio, calcular precio mayorista con descuento, calcular comisión bancaria y exportar o compartir precios",
        keywords: "calculadora de precios, precio de venta, margen de ganancia, IVA Honduras, precio mayorista, emprendedores Honduras, calcular costo de producto",
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "HNL",
          availability: "https://schema.org/InStock",
        },
        audience: {
          "@type": "BusinessAudience",
          audienceType: "Emprendedores y pequeños negocios en Honduras",
        },
        creator: {
          "@type": "Organization",
          name: publisherName,
          url: "https://cfv.technology",
        },
        publisher: {
          "@type": "Organization",
          name: publisherName,
          url: "https://cfv.technology",
        },
        inLanguage: "es-HN",
        isAccessibleForFree: true,
        countryOfOrigin: {
          "@type": "Country",
          name: "Honduras",
        },
      })}
    />
    {faq.length > 0 && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "FAQPage",
          mainEntity: faq.map((item) => ({
            "@type": "Question",
            name: item.question,
            acceptedAnswer: {
              "@type": "Answer",
              text: item.answer,
            },
          })),
        })}
      />
    )}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Analytics -->
    <script is:inline defer src="https://analisis.cfv.technology/script.js" data-website-id="c53efaa7-5b0b-4225-ab04-23f7ea74850c"></script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/cfv-icon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <slot name="head" />
  </head>
  <body data-theme="dark">
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <slot />
  </body>
</html>
