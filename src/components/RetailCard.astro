---
import Card from "./Card.astro";
import BreakdownRow from "./BreakdownRow.astro";
import MarginIndicator from "./MarginIndicator.astro";
import ShareButton from "./ShareButton.astro";
---

<Card title="Precio al detalle" badge="Detalle" animationDelay="0.1s">
  <div id="productDisplay" style="display: none" class="product-display">
    <div class="product-display-label">Producto</div>
    <div class="product-display-name" id="productDisplayName">&mdash;</div>
  </div>

  <div class="result-headline">
    <div class="price-header">
      <div>
        <div class="result-label">Precio final</div>
        <div class="result-price accent">
          <span class="currency">L</span>
          <output id="finalPrice" aria-live="polite">0.00</output>
        </div>
      </div>
      <div class="actions-group">
        <button class="icon-btn" onclick="copyPrice('retail')" title="Copiar precio" aria-label="Copiar precio">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
        </button>
        <ShareButton id="retailShareMenu" />
      </div>
    </div>

    <dl class="result-meta">
      <div class="meta-item">
        <dt class="meta-label">Ganancia neta</dt>
        <dd class="meta-value positive" id="netProfit">L 0.00</dd>
      </div>
      <div class="meta-item">
        <dt class="meta-label">Margen real</dt>
        <dd class="meta-value positive" id="netMargin">0.0%</dd>
      </div>
    </dl>
  </div>

  <MarginIndicator
    containerId="retailMarginIndicator"
    healthValueId="marginHealthValue"
    fillId="marginFill"
    defaultLabel="Óptimo"
  />

  <dl class="breakdown">
    <BreakdownRow label="Costo base" valueId="br-cost" markerType="neutral" />
    <BreakdownRow label="Ganancia" valueId="br-profit" markerType="add" pctId="br-profit-pct" defaultPct="100%" highlighted />
    <BreakdownRow label="Publicidad" valueId="br-mkt" markerType="add" pctId="br-mkt-pct" defaultPct="10%" />
    <BreakdownRow label="Otros" valueId="br-other" markerType="add" pctId="br-other-pct" defaultPct="0%" />
    <BreakdownRow label="Subtotal" valueId="br-subtotal" isSubtotal />
    <BreakdownRow label="IVA" valueId="br-iva" markerType="add" pctId="br-iva-pct" defaultPct="15%" />
    <BreakdownRow label="Comisión banco" valueId="br-fee" markerType="add" pctId="br-fee-pct" defaultPct="4.5%" />
  </dl>
</Card>

<style>
  .product-display {
    margin-bottom: 20px;
    padding: 14px 16px;
    background: rgba(var(--cfv-accent-rgb), 0.05);
    border-left: 2px solid var(--cfv-accent);
    border-radius: 0 10px 10px 0;
  }

  :global([data-theme="light"]) .product-display {
    background: rgba(var(--cfv-accent-rgb), 0.05);
    border-left-color: var(--cfv-primary);
  }

  .product-display-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--cfv-neutral);
    margin-bottom: 4px;
  }

  .product-display-name {
    font-family: "Instrument Serif", serif;
    font-style: italic;
    font-size: 18px;
    color: var(--cfv-accent);
  }

  :global([data-theme="light"]) .product-display-name {
    color: var(--cfv-primary);
  }

  .result-headline {
    margin-bottom: 20px;
  }

  .price-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .result-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--cfv-neutral);
    margin-bottom: 6px;
  }

  .result-price {
    font-family: "Space Grotesk", sans-serif;
    font-weight: 700;
    font-size: 42px;
    letter-spacing: -1.5px;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .result-price .currency {
    font-size: 18px;
    font-weight: 500;
    color: var(--cfv-neutral);
  }

  .result-price.accent {
    color: var(--cfv-accent);
  }

  :global([data-theme="light"]) .result-price.accent {
    color: var(--cfv-primary);
  }

  .result-meta {
    display: flex;
    gap: 16px;
    margin: 0;
    margin-top: 12px;
    padding: 0;
    flex-wrap: wrap;
  }

  .result-meta .meta-value {
    margin: 0;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .meta-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--cfv-neutral);
  }

  .meta-value {
    font-family: "Space Grotesk", sans-serif;
    font-size: 14px;
    font-weight: 600;
  }

  .meta-value.positive {
    color: var(--cfv-accent);
  }

  :global([data-theme="light"]) .meta-value.positive {
    color: var(--cfv-primary);
  }

  .actions-group {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .breakdown {
    margin: 0;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px dashed rgba(var(--cfv-accent-rgb), 0.15);
  }

  :global([data-theme="light"]) .breakdown {
    border-top-color: var(--cfv-border-subtle);
  }
</style>
