---
import Layout from "../layouts/Layout.astro";
import AppBackground from "../components/AppBackground.astro";
import PageHeader from "../components/PageHeader.astro";
import PageTitle from "../components/PageTitle.astro";
import InputCard from "../components/InputCard.astro";
import RetailCard from "../components/RetailCard.astro";
import WholesaleCard from "../components/WholesaleCard.astro";
import CopyToast from "../components/CopyToast.astro";
import FAQ from "../components/FAQ.astro";
import { faqData } from "../components/FAQ.astro";
import PageFooter from "../components/PageFooter.astro";
import "../styles/global.css";
---

<Layout
  title="Calculadora de precios de venta gratis — Lempira | Margen de ganancia, IVA y mayorista"
  description="Calculá el precio de venta de tu producto gratis. Definí costo, margen de ganancia, IVA, comisión bancaria y descuento mayorista. Obtené tu precio justo al detalle y por mayor en Lempiras (HNL). Herramienta gratuita para emprendedores hondureños."
  faq={faqData}
>
  <AppBackground />

  <div class="container">
    <PageHeader />
    <main>
      <PageTitle />

      <section class="layout" aria-label="Calculadora de precios">
        <InputCard />

        <div class="results">
          <RetailCard />
          <WholesaleCard />
        </div>
      </section>

      <FAQ />
    </main>
    <PageFooter />
  </div>

  <CopyToast />

  <script src="../scripts/calculator.ts"></script>
</Layout>
