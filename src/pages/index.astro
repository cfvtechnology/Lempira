---
import Layout from "../layouts/Layout.astro";
import AppBackground from "../components/AppBackground.astro";
import PageHeader from "../components/PageHeader.astro";
import PageTitle from "../components/PageTitle.astro";
import InputCard from "../components/InputCard.astro";
import RetailCard from "../components/RetailCard.astro";
import WholesaleCard from "../components/WholesaleCard.astro";
import CopyToast from "../components/CopyToast.astro";
import PageFooter from "../components/PageFooter.astro";
import "../styles/global.css";
---

<Layout
  title="Lempira · Calculadora de precios para Honduras"
  description="Lempira es la calculadora de precios gratis para emprendedores hondureños. Definí costos, márgenes, IVA e impuestos. Obtené tu precio justo al detalle y mayorista en tiempo real, en Lempiras (HNL). Hecha por CFV Technology."
>
  <AppBackground />

  <div class="container">
    <PageHeader />
    <main>
      <PageTitle />

      <section class="layout" aria-label="Calculadora de precios">
        <InputCard />

        <div class="results">
          <RetailCard />
          <WholesaleCard />
        </div>
      </section>
    </main>
    <PageFooter />
  </div>

  <CopyToast />

  <script src="../scripts/calculator.ts"></script>
</Layout>
