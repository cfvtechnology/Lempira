---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout
  title="Calculadora de Pricing · CFV Technology"
  description="Calculadora de precios para Honduras. Definí costos, márgenes, IVA e impuestos. Obtené el precio óptimo al detalle y mayorista en tiempo real, en Lempiras (HNL)."
>
  <div class="bg-glow bg-glow-tr"></div>
  <div class="bg-glow bg-glow-bl"></div>
  <div class="bg-grid"></div>

  <div class="container">
    <!-- Header -->
    <header class="header">
      <div class="brand">
        <div class="brand-logo">
            <img src="/logo-cfv-dark.svg" alt="CFV Technology" class="brand-logo-dark" />
            <img src="/logo-cfv-light.svg" alt="CFV Technology" class="brand-logo-light" />
          </div>
        <div class="brand-text">
          <span class="brand-name">CFV Technology</span>
          <span class="brand-sub">Pricing suite</span>
        </div>
      </div>

      <div class="theme-toggle">
        <button
          class="theme-btn active"
          data-theme-btn="dark"
          onclick="setTheme('dark')"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          Dark
        </button>
        <button
          class="theme-btn"
          data-theme-btn="light"
          onclick="setTheme('light')"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
          Light
        </button>
      </div>
    </header>

    <!-- Title -->
    <section class="title-section">
      <div class="kicker">
        <span class="kicker-line"></span>
        <span class="kicker-text"
          >Calculadora de pricing &middot; Honduras</span
        >
      </div>
      <h1>Tu precio final, <span class="accent-word">calculado.</span></h1>
      <p class="subtitle">
        Definí costos, márgenes e impuestos. Obtené el precio óptimo al detalle
        y mayorista en tiempo real, sin planillas.
      </p>
    </section>

    <!-- Main layout -->
    <div class="layout">
      <!-- INPUTS COLUMN -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">Datos del producto</span>
          <span class="card-badge">Inputs</span>
        </div>

        <div class="field-group">
          <label class="field-label" for="productName"
            >Nombre del producto
            <span
              style="color: var(--cfv-neutral); font-weight: 400; letter-spacing: 0; text-transform: none;"
              >&mdash; opcional</span
            ></label
          >
          <div class="input-wrap">
            <input
              type="text"
              id="productName"
              class="field"
              placeholder="Ej: Brazalete"
              oninput="calculate()"
            />
          </div>
        </div>

        <div class="field-group">
          <label class="field-label" for="cost"
            >Precio de costo <span class="req">*</span></label
          >
          <div class="input-wrap">
            <span class="input-prefix">L</span>
            <input
              type="number"
              id="cost"
              class="field with-prefix"
              value="333"
              step="0.01"
              min="0"
              oninput="calculate()"
            />
          </div>
        </div>

        <div class="field-group grid-2">
          <div>
            <label class="field-label" for="profit"
              >Ganancia <span class="req">*</span></label
            >
            <div class="input-wrap">
              <input
                type="number"
                id="profit"
                class="field with-suffix"
                value="30"
                step="0.1"
                min="0"
                max="1000"
                oninput="calculate()"
              />
              <span class="input-suffix">%</span>
            </div>
          </div>
          <div>
            <label class="field-label" for="iva">IVA</label>
            <div class="input-wrap">
              <input
                type="number"
                id="iva"
                class="field with-suffix"
                value="15"
                step="0.1"
                min="0"
                max="100"
                oninput="calculate()"
              />
              <span class="input-suffix">%</span>
            </div>
          </div>
        </div>

        <div class="field-group grid-2">
          <div>
            <label class="field-label" for="bankFee">Fee del banco</label>
            <div class="input-wrap">
              <input
                type="number"
                id="bankFee"
                class="field with-suffix"
                value="3.5"
                step="0.01"
                min="0"
                max="100"
                oninput="calculate()"
              />
              <span class="input-suffix">%</span>
            </div>
          </div>
          <div>
            <label class="field-label" for="marketing">Publicidad</label>
            <div class="input-wrap">
              <input
                type="number"
                id="marketing"
                class="field with-suffix"
                value="10"
                step="0.1"
                min="0"
                max="100"
                oninput="calculate()"
              />
              <span class="input-suffix">%</span>
            </div>
          </div>
        </div>

        <div class="field-group grid-2">
          <div>
            <label class="field-label" for="otherCosts">Otros costos</label>
            <div class="input-wrap">
              <input
                type="number"
                id="otherCosts"
                class="field with-suffix"
                value="0"
                step="0.1"
                min="0"
                max="100"
                oninput="calculate()"
              />
              <span class="input-suffix">%</span>
            </div>
          </div>
          <div>
            <label class="field-label" for="wholesaleDiscount"
              >Dcto. mayorista</label
            >
            <div class="input-wrap">
              <input
                type="number"
                id="wholesaleDiscount"
                class="field with-suffix"
                value="30"
                step="0.1"
                min="0"
                max="100"
                oninput="calculate()"
              />
              <span class="input-suffix">%</span>
            </div>
          </div>
        </div>

        <div class="actions">
          <button class="btn btn-ghost" onclick="resetForm()">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M1 4v6h6"></path>
              <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
            </svg>
            Limpiar
          </button>
        </div>
      </div>

      <!-- RESULTS COLUMN -->
      <div>
        <div class="results" id="resultsContainer">
          <!-- Retail card -->
          <div
            class="card animate-in"
            style="animation-delay: 0.1s; opacity: 0"
          >
            <div class="card-header">
              <span class="card-title">Precio al detalle</span>
              <span class="card-badge">Retail</span>
            </div>

            <div
              id="productDisplay"
              style="display: none"
              class="product-display"
            >
              <div class="product-display-label">Producto</div>
              <div class="product-display-name" id="productDisplayName">
                &mdash;
              </div>
            </div>

            <div class="result-headline">
              <div
                style="display: flex; justify-content: space-between; align-items: flex-end;"
              >
                <div>
                  <div class="result-label">Precio final</div>
                  <div class="result-price accent">
                    <span class="currency">L</span>
                    <span id="finalPrice">0.00</span>
                  </div>
                </div>
                <button
                  class="icon-btn"
                  onclick="copyPrice('retail')"
                  title="Copiar precio"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                    ></rect>
                    <path
                      d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                    ></path>
                  </svg>
                </button>
              </div>

              <div class="result-meta">
                <div class="meta-item">
                  <span class="meta-label">Ganancia neta</span>
                  <span class="meta-value positive" id="netProfit">L 0.00</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Margen real</span>
                  <span class="meta-value positive" id="netMargin">0.0%</span>
                </div>
              </div>
            </div>

            <div class="margin-indicator" id="retailMarginIndicator">
              <div class="margin-top">
                <span class="margin-top-label">Salud del margen</span>
                <span class="margin-top-value" id="marginHealthValue"
                  >Óptimo</span
                >
              </div>
              <div class="margin-bar">
                <div
                  class="margin-fill"
                  id="marginFill"
                  style="width: 0%"
                ></div>
              </div>
            </div>

            <div class="breakdown">
              <div class="row">
                <span class="row-label"
                  ><span class="marker neutral"></span>Costo base</span
                >
                <span class="row-value" id="br-cost">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>Ganancia
                  <span
                    id="br-profit-pct"
                    style="opacity: 0.5; font-size: 11px">(30%)</span
                  ></span
                >
                <span class="row-value highlighted" id="br-profit">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>Publicidad
                  <span
                    id="br-mkt-pct"
                    style="opacity: 0.5; font-size: 11px">(10%)</span
                  ></span
                >
                <span class="row-value" id="br-mkt">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>Otros
                  <span
                    id="br-other-pct"
                    style="opacity: 0.5; font-size: 11px">(0%)</span
                  ></span
                >
                <span class="row-value" id="br-other">L 0.00</span>
              </div>
              <div class="row subtotal">
                <span class="row-label">Subtotal</span>
                <span class="row-value" id="br-subtotal">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>IVA
                  <span
                    id="br-iva-pct"
                    style="opacity: 0.5; font-size: 11px">(15%)</span
                  ></span
                >
                <span class="row-value" id="br-iva">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>Fee banco
                  <span
                    id="br-fee-pct"
                    style="opacity: 0.5; font-size: 11px">(3.5%)</span
                  ></span
                >
                <span class="row-value" id="br-fee">L 0.00</span>
              </div>
            </div>
          </div>

          <!-- Wholesale card -->
          <div
            id="wholesaleCard"
            class="card animate-in"
            style="animation-delay: 0.2s; opacity: 0; display: none;"
          >
            <div class="card-header">
              <span class="card-title">Precio mayorista</span>
              <span class="card-badge">Wholesale</span>
            </div>

            <div class="result-headline">
              <div
                style="display: flex; justify-content: space-between; align-items: flex-end;"
              >
                <div>
                  <div class="result-label">Precio mayorista</div>
                  <div class="result-price primary">
                    <span class="currency">L</span>
                    <span id="wholesalePrice">0.00</span>
                  </div>
                </div>
                <button
                  class="icon-btn"
                  onclick="copyPrice('wholesale')"
                  title="Copiar precio"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                    ></rect>
                    <path
                      d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                    ></path>
                  </svg>
                </button>
              </div>

              <div class="result-meta">
                <div class="meta-item">
                  <span class="meta-label">Ganancia neta</span>
                  <span class="meta-value" id="wholesaleProfit">L 0.00</span>
                </div>
                <div class="meta-item">
                  <span class="meta-label">Margen real</span>
                  <span class="meta-value" id="wholesaleMargin">0.0%</span>
                </div>
              </div>
            </div>

            <div class="margin-indicator" id="wholesaleMarginIndicator">
              <div class="margin-top">
                <span class="margin-top-label">Salud del margen</span>
                <span class="margin-top-value" id="wholesaleHealthValue"
                  >&mdash;</span
                >
              </div>
              <div class="margin-bar">
                <div
                  class="margin-fill"
                  id="wholesaleMarginFill"
                  style="width: 0%"
                ></div>
              </div>
            </div>

            <div class="breakdown">
              <div class="row">
                <span class="row-label"
                  ><span class="marker neutral"></span>Subtotal detalle</span
                >
                <span class="row-value" id="wh-subtotal">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker sub"></span>Dcto. s/ganancia
                  <span
                    id="wh-disc-pct"
                    style="opacity: 0.5; font-size: 11px">(30%)</span
                  ></span
                >
                <span
                  class="row-value"
                  style="color: #ef6b6b"
                  id="wh-discount">L 0.00</span
                >
              </div>
              <div class="row subtotal">
                <span class="row-label">Subtotal mayorista</span>
                <span class="row-value" id="wh-submayorista">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>IVA</span
                >
                <span class="row-value" id="wh-iva">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker add"></span>Fee banco</span
                >
                <span class="row-value" id="wh-fee">L 0.00</span>
              </div>
              <div class="row">
                <span class="row-label"
                  ><span class="marker neutral"></span>Pub + Otros</span
                >
                <span class="row-value" id="wh-extras">L 0.00</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <span class="footer-accent">CFV Technology</span> &middot; Calculadora de
      pricing &middot; Moneda Lempiras (HNL)
    </footer>
  </div>

  <!-- Copy toast -->
  <div class="copy-toast" id="copyToast">
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
    <span id="copyToastText">Precio copiado</span>
  </div>

  <script src="../scripts/calculator.ts"></script>
</Layout>
