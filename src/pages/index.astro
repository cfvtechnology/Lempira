---
import Layout from "../layouts/Layout.astro";
import AppBackground from "../components/AppBackground.astro";
import PageHeader from "../components/PageHeader.astro";
import PageTitle from "../components/PageTitle.astro";
import InputCard from "../components/InputCard.astro";
import RetailCard from "../components/RetailCard.astro";
import WholesaleCard from "../components/WholesaleCard.astro";
import CopyToast from "../components/CopyToast.astro";
import FAQ from "../components/FAQ.astro";
import LiveAnnouncer from "../components/LiveAnnouncer.astro";
import { faqData } from "../data/faq";
import PageFooter from "../components/PageFooter.astro";
import "../styles/global.css";
---

<Layout
  title="Calculadora de precio de venta — Lempira Honduras"
  description="Calculá el precio de venta de tu producto en Honduras. Sumá costo, ganancia, IVA, comisión bancaria y precio mayorista gratis con Lempira."
  faq={faqData}
>
  <AppBackground />

  <div class="container">
    <PageHeader />
    <main id="main-content">
      <PageTitle />

      <section class="layout" aria-label="Calculadora de precios">
        <InputCard />

        <div class="results">
          <RetailCard />
          <WholesaleCard />
        </div>
      </section>

      <FAQ />
    </main>
    <PageFooter />
  </div>

  <CopyToast />
  <LiveAnnouncer />

  <script src="../scripts/calculator.ts"></script>
</Layout>
